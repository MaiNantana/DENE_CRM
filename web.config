<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- ปิด WebDAV ที่บล็อก PUT / PATCH / DELETE -->
    <modules>
      <remove name="WebDAVModule" />
    </modules>
    <handlers>
      <remove name="WebDAV" />
      <add name="iisnode-crm-api"
           path="server/entry.cjs"
           verb="*"
           modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- Root → admin -->
        <rule name="RootRedirect" stopProcessing="true">
          <match url="^$" />
          <action type="Redirect" url="/admin" redirectType="Found" appendQueryString="true" />
        </rule>

        <!-- /api/* → iisnode → server/entry.cjs -->
        <rule name="API" stopProcessing="true">
          <match url="^api(/.*)?$" />
          <action type="Rewrite" url="server/entry.cjs" />
        </rule>

        <!-- SPA fallback for admin and LIFF routes -->
        <rule name="SPA" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{URL}" pattern="^api(/.*)?$" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>

    <iisnode
      node_env="production"
      loggingEnabled="true"
      logDirectory="iisnode-logs"
      debuggingEnabled="false"
      devErrorsEnabled="false" />

    <!-- ให้ IIS ส่ง response จาก Node.js ตรงๆ ไม่กั้น 4xx/5xx -->
    <httpErrors existingResponse="PassThrough" />

  </system.webServer>
</configuration>
