# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
# Optional secret used to sign slip verification tokens.
SLIP_ANALYSIS_SECRET="MY_SLIP_ANALYSIS_SECRET"
# Optional model override for slip analysis.
GEMINI_SLIP_MODEL="gemini-2.5-flash"
# Optional minimum confidence required before a slip can be submitted.
SLIP_MIN_CONFIDENCE="0.72"
# Optional storage directory for verified slip images.
SLIP_STORAGE_DIR="server/uploads/slips"

# APP_URL (public base URL of the site; LIFF lives under /liff)
APP_URL="MY_APP_URL"

# LIFF
# ใช้ค่าเดียวกันทั้งฝั่งหน้าเว็บและสคริปต์สร้าง rich menu
VITE_LIFF_ID="MY_LIFF_ID"
VITE_LIFF_ID_DENE="MY_DENE_LIFF_ID"
VITE_LIFF_ID_KEFERA="MY_KEFERA_LIFF_ID"

# Database
DB_HOST=hr.iexcellence.cloud
DB_PORT=3307
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=mtcrm

# Backend API port
PORT=3001

# Auth
AUTH_SECRET=change_this_to_a_long_random_secret
AUTH_SESSION_TTL_MS=43200000
AUTH_COOKIE_SECURE=0
